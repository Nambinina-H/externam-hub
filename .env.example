# ============================================================
# Externam Hub — variables d'environnement (racine, partagées par docker-compose)
# Copier en `.env` puis adapter les valeurs.
# ============================================================

# ---------- Environnement ----------
ENVIRONMENT=local

# ---------- Ports ----------
# Backend : port d'écoute en dev local (lu par apps/backend/run.py) ET mapping hôte docker-compose.
#   Change-le si 8000 est déjà pris (ex. API_PORT=8001) et adapte API_URL/BASE_URL en conséquence.
API_PORT=8000
# Frontend : mapping hôte docker-compose. En dev local, Next bascule tout seul sur un port libre
#   si 3000 est pris ; pour forcer un port précis : `PORT=3001 npm run dev:frontend`.
FRONT_PORT=3000

# ---------- PostgreSQL ----------
POSTGRES_USER=externam
POSTGRES_PASSWORD=change_me_postgres
POSTGRES_DB=externam
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Base managée (Railway, etc.) : si défini, prend le dessus sur les POSTGRES_* ci-dessus.
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/db

# ---------- Seed admin (créé au démarrage s'il n'existe pas) ----------
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin1234
SEED_ADMIN_FIRSTNAME=Admin
SEED_ADMIN_LASTNAME=Externam Hub

# ---------- JWT (RSA / RS256) ----------
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=keys/private.pem
JWT_PUBLIC_KEY_PATH=keys/public.pem
# PaaS (Railway) sans fichier : coller le CONTENU des PEM ci-dessous (prioritaire sur les *_PATH).
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=
ACCESS_TOKEN_EXPIRATION=900
REFRESH_TOKEN_EXPIRATION=604800

# ---------- URLs ----------
BASE_URL=http://localhost:8000
FRONT_BASE_URL=http://localhost:3000

# ---------- Frontend (Next.js) ----------
API_URL=http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000

# ---------- Tâches planifiées (APScheduler in-process) ----------
SCHEDULER_ENABLED=true

# ---------- Monitoring ----------
SENTRY_URL=

# ---------- Email (SMTP) ----------
# Tant que SMTP_USER est vide, les emails sont loggés au lieu d'être envoyés (dev hors-ligne).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=noreply@externam-hub.com

# ---------- Rapports ads hebdo ----------
# Heure (0-23) du cron quotidien ; le jour d'envoi est défini par client.
REPORT_SEND_HOUR=9
# Meta Ads (Marketing API) — sans META_ACCESS_TOKEN, le provider reste en stub déterministe
META_GRAPH_VERSION=v25.0
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=

# ---------- Déploiement VPS (docker-compose.prod.yml) ----------
HTTP_PORT=80
